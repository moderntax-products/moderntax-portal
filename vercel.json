{
  "crons": [
    {
      "path": "/api/cron/nudge",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/sla-warning",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/admin-daily-summary",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/manager-weekly-summary",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/8821-reminder",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/auto-sync-8821",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/auto-assign-experts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/auto-complete-requests",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/stuck-entity-alert",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/auto-invoice",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/webhook-retry",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/monitoring-repull",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/clearfirm-8821",
      "schedule": "0 15 * * *"
    }
  ],
  "headers": [
    {
      "source": "/irs-batch-v6.js",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET" },
        { "key": "Content-Type", "value": "application/javascript" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/api/expert/batch-upload",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://la.www4.irs.gov" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}

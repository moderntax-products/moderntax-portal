{
  "crons": [
    {
      "path": "/api/cron/nudge",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/sla-warning",
      "schedule": "0 12 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
